// Command terraform-provider-{{.Name}} is a runnable terraform-plugin-framework
// provider generated from an enriched OpenAPI v3 spec. It is the Terraform mirror
// of a devedge CLI shell: a small hand-written entry point composing the
// open-core github.com/infobloxopen/devedge-terraform-sdk tfkit runtime
// (internal/provider/provider.go) with resource modules generated by
// "de terraform add".
//
// Add a resource with: de terraform add --input <spec> --resource <name>
// which runs tfgen to emit internal/provider/<name>_resource*.go and rewrite
// internal/provider/resources_gen.go.
package main

import (
	"context"
	"flag"
	"log"

	"github.com/hashicorp/terraform-plugin-framework/providerserver"

	"{{.Module}}/internal/provider"
)

// version is overridden at release time via -ldflags (see .goreleaser.yaml).
var version = "dev"

func main() {
	var debug bool
	flag.BoolVar(&debug, "debug", false, "run with support for debuggers like delve")
	flag.Parse()

	err := providerserver.Serve(context.Background(), provider.New(version), providerserver.ServeOpts{
		Address: "registry.terraform.io/{{.Org}}/{{.Name}}",
		Debug:   debug,
	})
	if err != nil {
		log.Fatal(err.Error())
	}
}
