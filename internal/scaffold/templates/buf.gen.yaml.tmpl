version: v2
# Generates into internal/gen/ (per the protos' go_package). The third_party
# protos are codegen inputs only — their Go types come from released modules.
inputs:
  - directory: proto
plugins:
  - local: protoc-gen-go
    out: .
    opt: module={{.Module}}
  - local: protoc-gen-go-grpc
    out: .
    opt: module={{.Module}}
  - local: protoc-gen-grpc-gateway
    out: .
    opt: module={{.Module}}
