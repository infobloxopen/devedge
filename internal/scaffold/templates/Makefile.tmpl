# {{.Name}} — top-level Makefile (hand-owned).
#
# `de` is the hermetic build authority: it owns codegen, build, test, lint, and
# the container image, with the buf CLI + codegen plugins PINNED by the `de`
# binary. There are no unpinned tool installs here — that logic lives in `de`.
# This Makefile just reads the managed shim `de sync` writes and adds the
# project-specific target(s) below. (You already have `de` — you ran
# `de project init`; regenerate the shim any time with `de sync`.)
#
# Fresh clone: internal/gen/ is generated code — run `de generate` first.
#     de generate    # buf generate -> internal/gen/, then go mod tidy
#     de build       # go build ./...
#     de test        # go test ./...
-include .devedge/make/devedge.mk

.PHONY: run

# Run the service locally (build + run the binary; it listens on :8080).
# internal/gen/ is generated — run `de generate` first on a fresh clone.
run:
	go run ./cmd/{{.Name}} serve
