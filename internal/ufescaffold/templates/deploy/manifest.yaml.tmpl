# Minimal deploy manifest for the {{ .TitleName }} uFE static bundle.
# The BASE scaffold ships this plain Deployment + Service; the FeatureFlag-CRD
# chart is provided by the internal preset, not here.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .AppID }}-ufe
  labels:
    app.kubernetes.io/name: {{ .AppID }}-ufe
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ .AppID }}-ufe
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ .AppID }}-ufe
    spec:
      containers:
        - name: {{ .AppID }}-ufe
          image: {{ .AppID }}-ufe:latest
          ports:
            - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: {{ .AppID }}-ufe
spec:
  selector:
    app.kubernetes.io/name: {{ .AppID }}-ufe
  ports:
    - port: 80
      targetPort: 80
