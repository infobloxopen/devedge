{
  "name": "{{ .Package }}",
  "version": "0.1.0",
  "description": "{{ .TitleName }} micro-frontend — Angular 15 + single-spa, wired to the devedge-ufe SDK.",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "ng build",
    "start": "ng serve --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "ng test",
    "doctor": "devedge-ufe doctor --url http://127.0.0.1:{{ .DevPort }} --app {{ .AppID }} --metadata metadata.js"
  },
  "dependencies": {
    "@angular/animations": "{{ .Versions.Angular }}",
    "@angular/common": "{{ .Versions.Angular }}",
    "@angular/compiler": "{{ .Versions.Angular }}",
    "@angular/core": "{{ .Versions.Angular }}",
    "@angular/forms": "{{ .Versions.Angular }}",
    "@angular/platform-browser": "{{ .Versions.Angular }}",
    "@angular/platform-browser-dynamic": "{{ .Versions.Angular }}",
    "@angular/router": "{{ .Versions.Angular }}",
    "@angular/cdk": "{{ .Versions.AngularMaterial }}",
    "@angular/material": "{{ .Versions.AngularMaterial }}",
    "@infobloxopen/devedge-ufe-core": "{{ .Versions.SDK }}",
    "@infobloxopen/devedge-ufe-angular": "{{ .Versions.SDK }}",
    "@infobloxopen/devedge-ufe-single-spa": "{{ .Versions.SDK }}",
    "@infobloxopen/devedge-ufe-oidc": "{{ .Versions.SDK }}",
    "@infobloxopen/devedge-ufe-dev-loop": "{{ .Versions.SDK }}",
    "single-spa": "^6.0.0",
    "single-spa-angular": "^8.0.0",
    "systemjs-webpack-interop": "^2.3.7",
    "core-js": "^3.36.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.12.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^15.0.0",
    "@angular-devkit/build-angular": "{{ .Versions.Angular }}",
    "@angular/cli": "{{ .Versions.Angular }}",
    "@angular/compiler-cli": "{{ .Versions.Angular }}",
    "typescript": "{{ .Versions.TypeScript }}",
    "webpack": "^5.90.0",
    "webpack-merge": "^5.10.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^13.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
