/**
 * The single-spa root-config for a devedge micro-frontend SHELL.
 *
 * Generated by `de ufe shell` from a `kind: Shell` roster (shell.yaml). This is
 * the SHELL/host: it owns the session exactly ONCE, registers every uFE in the
 * roster by HASH route, loads each uFE's bundle through the browser's native
 * importmap (see index.html), and starts single-spa. A uFE never constructs a
 * session and never owns this file.
 *
 * uFE selection is by HASH route (single-spa reads location.hash), so the edge
 * never sees the uFE surface — only each uFE's CDN asset path is routed.
 */
// The shell/host loads zone.js ONCE for the whole page. Angular uFEs need a
// global Zone; in a micro-frontend it must be loaded by the host (not bundled
// per-uFE, which risks multiple Zone instances). Each uFE build keeps zone.js in
// a separate polyfills entry the native-import loader does not fetch, so the
// host supplies it here — before any uFE bootstraps.
import 'zone.js';

import { start } from 'single-spa';
import { OidcSessionProvider } from '@infobloxopen/devedge-ufe-oidc';
import {
  createShell,
  type SingleSpaLifecycles,
} from '@infobloxopen/devedge-ufe-single-spa';
import {
  StubSessionProvider,
  type SessionProvider,
} from '@infobloxopen/devedge-ufe-core';

import { environment } from './environment';

/**
 * Builds a single-spa `activeWhen` predicate for a hash route. The uFE is active
 * when the URL hash is exactly the route or a sub-path of it (`#route`,
 * `#route/123`) — this is HASH routing, not path routing: single-spa reads
 * `location.hash`, so the edge never sees the uFE surface.
 */
function activeOnHash(route: string): (location: Location) => boolean {
  return (location: Location) =>
    location.hash === route || location.hash.startsWith(`${route}/`);
}

/**
 * Native dynamic import against the bare specifier, resolved by the
 * <script type="importmap"> in index.html. `import(/* webpackIgnore: true *​/ …)`
 * keeps a bundler from rewriting the specifier at build time, so the import goes
 * through the runtime importmap to the CDN bundle.
 *
 * A uFE builds a webpack UMD bundle (`library:'<id>'`, `libraryTarget:'umd'`),
 * so a native `import()` yields an empty ESM namespace and the single-spa
 * lifecycles land on `globalThis['<id>']`. We therefore check, in order: the
 * module's own `mount` (native ESM), a `default.mount` (interop default), then
 * `globalThis[globalName]` (the UMD global).
 */
async function loadMfe(spec: string, globalName: string): Promise<SingleSpaLifecycles> {
  const mod = (await import(/* webpackIgnore: true */ spec)) as Record<string, unknown>;
  const g = globalThis as Record<string, unknown>;
  const cand =
    typeof (mod as { mount?: unknown }).mount === 'function' ? mod
    : (mod as { default?: { mount?: unknown } }).default && typeof (mod as { default?: { mount?: unknown } }).default!.mount === 'function' ? (mod as { default: unknown }).default
    : g[globalName];
  const lc = cand as SingleSpaLifecycles | undefined;
  if (!lc || typeof lc.mount !== 'function') {
    throw new Error(`uFE "${spec}": no single-spa lifecycles found (checked ESM exports and globalThis["${globalName}"] — bundle library target?)`);
  }
  return lc;
}

/** Boots the shell: owns the session, registers the roster uFE(s), starts. */
export async function bootShell(): Promise<void> {
  // The shell owns the session — instantiated exactly ONCE. The provider is
  // chosen by `environment.useDevSession`: a no-auth StubSessionProvider so the
  // shell renders locally without an OIDC issuer, or the generic
  // OidcSessionProvider (point `authority` at any issuer). A uFE never
  // constructs a session either way.
  let session: SessionProvider;
  if (environment.useDevSession) {
    session = new StubSessionProvider();
  } else {
    const oidc = new OidcSessionProvider({
      authority: environment.oidc.authority,
      clientId: environment.oidc.clientId,
      redirectUri: environment.oidc.redirectUri,
      silentRedirectUri: environment.oidc.silentRedirectUri,
      scope: environment.oidc.scope,
    });
    // Complete the auth-code / silent-renew redirects on their dedicated paths.
    // These are OIDC redirect endpoints (path-based), independent of the uFE
    // hash routing above.
    if (location.pathname === '/callback') {
      await oidc.completeLoginRedirect();
      history.replaceState(null, '', '/');
    } else if (location.pathname === '/silent-refresh') {
      await oidc.completeSilentRedirect();
      return;
    }
    session = oidc;
  }

  // Register every uFE in the roster. createShell awaits getToken() FIRST
  // (proves the shell holds a session) and threads `session` into each uFE as a
  // HostProp. Each uFE is selected by its HASH route and loaded via the native
  // importmap; the app id, the import-map specifier, and the UMD global are the
  // same string.
  const shell = createShell({
    session,
    apps: [
{{- range .UFEs }}
      { name: '{{ .ID }}', activeWhen: activeOnHash('#{{ .Route }}'), load: () => loadMfe('{{ .ID }}', '{{ .ID }}') },
{{- end }}
    ],
  });
  await shell.registerAll();

  // Default to the first side-nav item so a uFE mounts on a bare load (no hash).
  if (!location.hash) {
    const first = document.querySelector<HTMLAnchorElement>('.side-nav a');
    if (first) location.hash = first.getAttribute('href') ?? '';
  }

  // Start single-spa. Registration already happened; start() begins reacting to
  // route (hash) changes and mounts the active uFE.
  start();

  // Host chrome: keep the side-nav's active item in sync with the route, and
  // show the signed-in user (read-only, from the shell-owned session).
  wireChrome(session);
}

/**
 * Wires the shell chrome to the router and session: highlights the side-nav
 * item matching the current hash on every change, and fills the signed-in-user
 * label from the shell-owned session's claims. Pure DOM — the chrome is host
 * markup (index.html), not a uFE.
 */
function wireChrome(session: SessionProvider): void {
  const links = () => Array.from(document.querySelectorAll<HTMLAnchorElement>('.side-nav a'));
  const highlight = () => {
    const hash = location.hash;
    for (const a of links()) {
      const route = a.getAttribute('href') ?? '';
      a.classList.toggle('active', hash === route || hash.startsWith(`${route}/`));
    }
  };
  window.addEventListener('hashchange', highlight);
  highlight();

  void session.getClaims().then((claims) => {
    const el = document.getElementById('shell-user');
    if (el) el.textContent = claims?.sub ? `Signed in as ${claims.sub}` : '';
  });
}

void bootShell();
